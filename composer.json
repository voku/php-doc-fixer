{
    "name": "voku/php-doc-fixer",
    "description": "Try to fix php types in the documentation",
    "type": "library",
    "keywords": [
        "php",
        "phpdoc"
    ],
    "homepage": "https://github.com/voku/php-doc-fixer",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Lars Moelleken",
            "homepage": "http://www.moelleken.org/"
        }
    ],
    "require": {
        "php": ">=7.4",
        "voku/simple-php-code-parser": "^0.16.6 || ^0.21",
        "voku/simple_html_dom": "^4.8",
        "voku/portable-utf8": "~5.4",
        "symfony/console": "^5.4 || ^6.4 || ^7.0",
        "symfony/finder": "^5.4 || ^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "jetbrains/phpstorm-stubs": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "voku\\": "src/voku/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "voku\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "scan-docs": "@php bin/phpdocfixer run --stubs-path=../php-src --stubs-file-extension=.stub.php",
        "fix-docs": "@php bin/phpdocfixer run --auto-fix=true --stubs-path=../php-src --stubs-file-extension=.stub.php"
    },
    "bin": [
        "bin/phpdocfixer"
    ]
}
